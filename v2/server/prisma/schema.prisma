generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [btree_gist]
}

// --- ENUMS ---

enum PropertyType {
  HOTEL_ROOM      // номера, спальные места
  APARTMENT       // квартиры, апартаменты
  HOUSE           // дома, коттеджи
  PRIVATE_ROOM    // отдельные комнаты
}

enum InternetAvailability {
  NONE
  FREE
  PAID
}

enum ParkingAvailability {
  NONE
  FREE
  PAID
}

enum PaymentMethodType {
  CASH_ONLY
  CARD_ONLY
  CASH_AND_CARD
  ANY
}

enum SmokingPolicy {
  FORBIDDEN
  DESIGNATED_AREAS
  ALLOWED
}

enum AdditionalServicePolicy {
  INCLUDED_IN_PRICE
  NOT_AVAILABLE
  AVAILABLE_FOR_FREE
  AVAILABLE_FOR_FEE
}

enum TransactionType {
  RENT
  SALE
}

enum PropertyStatus {
  DRAFT      // Черновик
  PENDING    // На модерации
  ACTIVE     // Опубликовано
  REJECTED   // Отклонено
  SOLD
  ARCHIVED
}

enum BookingStatus {
  PENDING    // Ожидает оплаты/подтверждения
  CONFIRMED  // Оплачено (Занято)
  CANCELLED  // Отменено
  COMPLETED  // Завершено
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  lastName  String?
  phone     String?
  city      String?
  role      String    @default("tenant") // tenant, landlord, moderator, admin
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  properties Property[]
  bookings   Booking[]
}

model Property {
  id              String         @id @default(uuid())
  ownerId         String?
  owner           User?          @relation(fields: [ownerId], references: [id])
  
  // Тип и категория
  type            PropertyType   @default(APARTMENT)
  subType         String?        @db.VarChar(100)
  categoryId      String?
  category        Category?      @relation(fields: [categoryId], references: [id])
  
  // Информация о здании/реестре
  title           String         @db.VarChar(255)
  registryNumber  String?        @db.VarChar(100)
  starRating      Int?           @default(0)
  registryType    String?        @db.VarChar(100)
  buildYear       Int?
  totalRooms      Int?           
  
  // Локация
  city            String?        @db.VarChar(100)
  address         String         // Полный адрес
  streetType      String?        @db.VarChar(50)  // улица, проспект
  streetName      String?        @db.VarChar(255)
  houseNumber     String?        @db.VarChar(20)
  buildingBlock   String?        @db.VarChar(20)  // корпус
  landmarks       String?        @db.Text
  
  // Характеристики
  description     String?        @db.Text
  pricePerNight   Decimal        @db.Decimal(12, 2)
  pricePer15Days  Decimal?       @db.Decimal(12, 2)
  transactionType TransactionType @default(RENT)
  rooms           Int            @default(1)
  bedrooms        Int            @default(1)
  beds            Int            @default(1)
  doubleBeds      Int            @default(0)
  maxGuests       Int            @default(2) 
  area            Float?         
  floor           Int?
  totalFloors     Int?
  
  // Правила
  checkIn         String?        @default("14:00")
  checkOut        String?        @default("12:00")
  smoking         SmokingPolicy? @default(FORBIDDEN)
  paymentMethod   PaymentMethodType? @default(ANY)
  animals         String?        // Можно, нельзя
  children        Boolean        @default(true)
  
  // Услуги и удобства
  internet        InternetAvailability? @default(NONE)
  parking         ParkingAvailability?  @default(NONE)
  
  // Питание
  isAllInclusive  Boolean        @default(false)
  breakfastType   String?      
  lunchType       String?      
  dinnerType      String?      
  
  // Доп. услуги
  cleaningService AdditionalServicePolicy? @default(NOT_AVAILABLE)
  bedLinen        AdditionalServicePolicy? @default(NOT_AVAILABLE)
  hasReportingDocs Boolean       @default(false)
  hasTransfer     Boolean        @default(false)
  
  // Флаги быстрого поиска (Legacy/Mixed)
  wifi            String?        // Legacy compatibility
  instantBooking  Boolean        @default(false)
  contactless     Boolean        @default(false)
  noDeposit       Boolean        @default(false)
  deposit         Decimal?       @db.Decimal(12, 2)

  // Рейтинг
  avgRating       Float          @default(4.5)
  reviewsCount    Int            @default(0)

  // Системные поля
  status          PropertyStatus @default(DRAFT)
  moderationComment String?      @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Связи
  images          PropertyImage[]
  bookings        Booking[]      
  hotelRooms      Room[]         
  amenityIds      String[]       
  amenitiesRelation PropertyAmenity[] 

  @@index([status, city, categoryId]) 
  @@index([pricePerNight])            
  @@index([rooms, area])              
  @@index([avgRating(sort: Desc), reviewsCount(sort: Desc)])
  @@index([type])
}

model Room {
  id          String   @id @default(uuid())
  title       String   
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  capacity    Int      @default(2)
  beds        Int      @default(1)
  size        Float?   
  amenityIds  String[] 
  
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  images      RoomImage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
}

model RoomImage {
  id      String @id @default(uuid())
  url     String
  order   Int    @default(0)
  roomId  String
  room    Room   @relation(fields: [roomId], references: [id])
}

model Booking {
  id           String        @id @default(uuid())
  propertyId   String
  property     Property      @relation(fields: [propertyId], references: [id])
  
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  
  checkInDate  DateTime      @db.Date 
  checkOutDate DateTime      @db.Date
  
  guestsCount  Int
  totalPrice   Decimal       @db.Decimal(12, 2)
  status       BookingStatus @default(PENDING)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([propertyId, status, checkInDate, checkOutDate])
}

model Category {
  id         String     @id @default(uuid())
  name       String     @unique
  slug       String     @unique
  properties Property[]
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  isPrimary  Boolean  @default(false)
  order      Int      @default(0)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  
  @@index([propertyId, isPrimary])
}

model Amenity {
  id         String            @id @default(uuid())
  category   String?           
  name       String            @unique
  groupId    String?            
  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  amenityId  String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  
  @@id([propertyId, amenityId])
}
